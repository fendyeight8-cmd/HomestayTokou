# ════════════════════════════════════════
# Rumah Alam — Environment Configuration
# Copy this to .env and fill in your values
# ════════════════════════════════════════

# ── Property ─────────────────────────────
PROPERTY_NAME=Rumah Alam
PROPERTY_LOCATION=Selangor, Malaysia
WHATSAPP_NUMBER=+601110085626

# ── Server ───────────────────────────────
HOST=0.0.0.0
PORT=8000
DEBUG=true

# ── Database ─────────────────────────────
# Default: SQLite (no config needed)
# For PostgreSQL, uncomment and fill:
# DATABASE_URL=postgresql://user:password@localhost:5432/homestay

# ── Session / Security ───────────────────
SECRET_KEY=change-me-to-a-long-random-secret-key-in-production

# ── Admin ────────────────────────────────
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme123
